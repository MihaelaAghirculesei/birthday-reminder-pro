# Prevent npm from using packages from parent directory node_modules.
# C:/Users/LG/node_modules/ contains Angular v20 (a different project)
# which conflicts with this project's Angular v19 when npm performs
# cross-directory deduplication during hoisted installs.
install-links=true

# @firebase/rules-unit-testing@3.x declares peer dep firebase@^10 but works
# fine with firebase@^12. legacy-peer-deps uses npm v6 resolution semantics
# to bypass the over-narrow peer constraint.
legacy-peer-deps=true
