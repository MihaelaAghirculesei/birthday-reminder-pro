# Birthday Reminder App - Environment Variables Template
#
# SETUP INSTRUCTIONS (CI/CD):
#   Set these as GitHub Actions Secrets (Settings → Secrets → Actions).
#   scripts/env-init.js reads them automatically during `npm run build`.
#
# SETUP INSTRUCTIONS (local dev):
#   Do NOT edit environment.ts directly. Use .env.local instead:
#     1. cp .env.local.example .env.local
#     2. Fill in your credentials in .env.local
#     3. npm run env:init   ← generates environment.ts from .env.local
#   .env.local is gitignored — credentials will never be committed.
#
# SECURITY NOTE:
#   Firebase web SDK credentials are NOT secrets by design — they are embedded
#   in the client bundle so the browser can reach Firebase APIs. Protect your
#   project via:
#     1. API key HTTP referrer restrictions — Google Cloud Console →
#        APIs & Services → Credentials → your API key → Application restrictions
#     2. Firebase Security Rules — only allow authenticated users to read/write

# ── Firebase ──────────────────────────────────────────────────────────────────
# Firebase Console → Project settings → Your apps → Config
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
FIREBASE_APP_ID=YOUR_APP_ID

# ── Google OAuth (shared by Firebase Auth + Google Calendar) ──────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

