# ─── Local development credentials ───────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real credentials.
#
# The app runs in offline/demo mode when these are absent.
# All values below are required for Firebase Auth + Firestore to work.
#
# Where to find these:
#   Firebase → Project settings → Your apps → Web app → Config
#   Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs

# Google OAuth client ID (used for both Calendar API and Firebase Google Sign-In)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# Firebase project config
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
# Use the .web.app domain (not .firebaseapp.com) to keep the auth popup
# same-origin with the app, avoiding Cross-Origin-Opener-Policy warnings.
FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.web.app
FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
FIREBASE_APP_ID=YOUR_APP_ID

# Sentry DSN for production error reporting (optional — app works without it)
# Sentry → your project → Settings → Client Keys (DSN)
SENTRY_DSN=
