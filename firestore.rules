rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Validate birthday document structure and field sizes
    function isValidBirthday() {
      let d = request.resource.data;
      return d.name is string && d.name.size() >= 1 && d.name.size() <= 200
          && d.date is string && d.date.size() <= 20
          && (!('notes' in d) || (d.notes is string && d.notes.size() <= 2000))
          && (!('categoryId' in d) || (d.categoryId is string && d.categoryId.size() <= 100))
          && (!('photoURL' in d) || (d.photoURL is string && d.photoURL.size() <= 500))
          && d.keys().hasOnly(['name', 'date', 'notes', 'categoryId', 'photoURL',
                                'id', 'createdAt', 'updatedAt', 'userId', 'notificationsEnabled',
                                'reminderDays', 'isDeleted', 'syncStatus']);
    }

    // Validate category document structure and field sizes
    function isValidCategory() {
      let d = request.resource.data;
      return d.name is string && d.name.size() >= 1 && d.name.size() <= 100
          && (!('color' in d) || (d.color is string && d.color.size() <= 20))
          && (!('icon' in d) || (d.icon is string && d.icon.size() <= 50))
          && d.keys().hasOnly(['name', 'color', 'icon', 'id', 'createdAt', 'updatedAt',
                                'userId', 'isDeleted', 'syncStatus']);
    }

    // Validate settings document structure
    function isValidSettings() {
      let d = request.resource.data;
      return d.keys().size() <= 30;
    }

    // User document rules
    match /users/{userId} {
      // Users can only read/write their own user doc
      allow read:          if isOwner(userId);
      allow create, update: if isOwner(userId)
                            && request.resource.data.keys().size() <= 20;
      allow delete:        if isOwner(userId);

      // Birthdays subcollection
      match /birthdays/{birthdayId} {
        allow read:          if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidBirthday();
        allow delete:        if isOwner(userId);
      }

      // Categories subcollection
      match /categories/{categoryId} {
        allow read:          if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidCategory();
        allow delete:        if isOwner(userId);
      }

      // Settings subcollection
      match /settings/{settingId} {
        allow read:          if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidSettings();
        allow delete:        if isOwner(userId);
      }
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
