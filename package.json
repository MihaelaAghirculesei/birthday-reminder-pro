{
  "name": "birthday-reminder-pro",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "env:init": "node scripts/env-init.js",
    "prestart": "npm run env:init",
    "start": "ng serve --port=4203",
    "prebuild": "npm run env:init",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "build:stats": "ng build --configuration production --stats-json",
    "analyze": "npm run build:stats && webpack-bundle-analyzer dist/birthday-reminder-pro/browser/stats.json",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:coverage": "ng test --no-watch --code-coverage",
    "test:coverage:watch": "ng test --code-coverage",
    "test:ci": "ng test --no-watch --code-coverage --browsers=ChromeHeadlessCI",
    "e2e": "cypress open",
    "e2e:headless": "cypress run",
    "pree2e:ci": "npx kill-port 4203 || true",
    "e2e:ci": "start-server-and-test start http://localhost:4203 e2e:headless",
    "serve:ssr:birthday-reminder-pro": "node dist/birthday-reminder-pro/server/server.mjs",
    "lint": "ng lint",
    "validate:ci": "node scripts/validate-ci.js",
    "ci:local": "npm run validate:ci && npm audit --omit=dev --audit-level=moderate && npm run lint && npx tsc --noEmit --strict --skipLibCheck -p tsconfig.app.json && npx tsc --noEmit --strict --skipLibCheck -p tsconfig.spec.json && npm test -- --watch=false --code-coverage && npm run e2e:ci && npm run build && node -e \"const fs=require('fs');const f=fs.readdirSync('dist/birthday-reminder-pro/browser').find(x=>x.startsWith('main-')&&x.endsWith('.js'));const s=fs.statSync('dist/birthday-reminder-pro/browser/'+f).size;console.log('Main bundle:',Math.round(s/1024)+'KB');if(s>512000){console.error('ERROR: Bundle > 500KB!');process.exit(1)}\"",
    "clean": "npx rimraf node_modules dist .angular",
    "clean:all": "npm cache clean --force && npx rimraf node_modules dist .angular",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.19",
    "@angular/cdk": "^19.2.19",
    "@angular/common": "^19.2.19",
    "@angular/compiler": "^19.2.19",
    "@angular/core": "^19.2.19",
    "@angular/forms": "^19.2.19",
    "@angular/material": "^19.2.19",
    "@angular/platform-browser": "^19.2.19",
    "@angular/platform-browser-dynamic": "^19.2.19",
    "@angular/platform-server": "^19.2.19",
    "@angular/router": "^19.2.19",
    "@angular/service-worker": "^19.2.19",
    "@angular/ssr": "^19.2.19",
    "@capacitor/android": "^7.4.4",
    "@capacitor/core": "^7.4.4",
    "@capacitor/local-notifications": "^7.0.3",
    "@ngrx/effects": "^19.2.1",
    "@ngrx/entity": "^19.2.1",
    "@ngrx/store": "^19.2.1",
    "express": "^4.18.2",
    "firebase": "^12.8.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zod": "^3.25.76",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.19",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^19.2.19",
    "@capacitor/cli": "^8.0.1",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@ngrx/store-devtools": "^19.2.1",
    "@types/express": "^4.17.17",
    "@types/jasmine": "^5.1.15",
    "@types/node": "^18.19.130",
    "angular-eslint": "21.0.1",
    "cypress": "^15.8.2",
    "eslint": "^9.39.1",
    "husky": "^9.1.7",
    "imagemin": "^9.0.1",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "lint-staged": "^16.2.7",
    "source-map-explorer": "^2.5.3",
    "start-server-and-test": "^2.1.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "8.46.4",
    "webpack-bundle-analyzer": "^5.1.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ],
    "*.html": [
      "eslint --fix"
    ]
  },
  "overrides": {
    "tar": "6.2.1",
    "@capacitor/cli": {
      "tar": "6.2.1"
    }
  }
}
