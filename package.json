{
  "name": "birthday-reminder-pro",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "env:init": "node scripts/env-init.js",
    "prestart": "npm run env:init",
    "start": "ng serve --port=4203",
    "prebuild": "npm run env:init",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "build:stats": "ng build --configuration production --stats-json",
    "analyze": "npm run build:stats && node scripts/analyze-bundle.js",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:coverage": "ng test --no-watch --code-coverage",
    "test:coverage:watch": "ng test --code-coverage",
    "test:ci": "ng test --no-watch --code-coverage",
    "e2e": "cypress open",
    "e2e:headless": "cypress run --config excludeSpecPattern=cypress/e2e/visual-regression.cy.ts",
    "prestart:ci": "node scripts/kill-port.js 4300",
    "start:ci": "ng serve --configuration ci --port=4300",
    "e2e:headless:ci": "cypress run --config baseUrl=http://127.0.0.1:4300,excludeSpecPattern=cypress/e2e/visual-regression.cy.ts",
    "e2e:ci": "start-server-and-test start:ci http-get://127.0.0.1:4300 e2e:headless:ci",
    "e2e:visual": "cypress run --spec cypress/e2e/visual-regression.cy.ts",
    "e2e:visual:ci:run": "cypress run --config baseUrl=http://127.0.0.1:4300 --spec cypress/e2e/visual-regression.cy.ts",
    "e2e:visual:ci": "start-server-and-test start:ci http-get://127.0.0.1:4300 e2e:visual:ci:run",
    "serve:ssr": "node dist/birthday-reminder-pro/server/server.mjs",
    "serve:ssr:birthday-reminder-pro": "node dist/birthday-reminder-pro/server/server.mjs",
    "preview": "npm run build:prod && npm run serve:ssr",
    "lint": "ng lint",
    "typecheck:app": "npx tsc --noEmit --strict --skipLibCheck -p tsconfig.app.json",
    "typecheck:spec": "npx tsc --noEmit --strict --skipLibCheck -p tsconfig.spec.json",
    "typecheck": "npm run typecheck:app && npm run typecheck:spec",
    "ci:audit": "node scripts/check-audit.js",
    "ci:bundle": "node scripts/check-bundle.js",
    "ci:security": "npm run ci:audit",
    "ci:quality": "npm run lint && npm run typecheck",
    "ci:build": "npm run build && npm run ci:bundle",
    "validate:ci": "node scripts/validate-ci.js",
    "ci:local": "npm run validate:ci && npm run ci:security && npm run ci:quality && npm run test:ci && npm run e2e:ci && npm run ci:build",
    "clean": "npx rimraf node_modules dist .angular",
    "clean:all": "npm cache clean --force && npx rimraf node_modules dist .angular",
    "postinstall": "node scripts/check-install.js",
    "prepare": "husky",
    "lighthouse:ci": "node scripts/kill-port.js 4000 && npm run build && npx @lhci/cli autorun",
    "test:rules": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config rules-tests/jest.config.mjs",
    "test:rules:ci": "firebase emulators:exec --only firestore,storage --project demo-birthday-rules \"npm run test:rules\""
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.22",
    "@angular/cdk": "^19.2.19",
    "@angular/common": "^19.2.22",
    "@angular/compiler": "^19.2.22",
    "@angular/core": "^19.2.22",
    "@angular/forms": "^19.2.22",
    "@angular/material": "^19.2.19",
    "@angular/platform-browser": "^19.2.22",
    "@angular/platform-browser-dynamic": "^19.2.22",
    "@angular/platform-server": "^19.2.22",
    "@angular/router": "^19.2.22",
    "@angular/service-worker": "^19.2.22",
    "@angular/ssr": "^19.2.25",
    "@ngrx/effects": "^19.2.1",
    "@ngrx/entity": "^19.2.1",
    "@ngrx/store": "^19.2.1",
    "@ngx-translate/core": "^16.0.4",
    "@sentry/browser": "^10.56.0",
    "compression": "^1.8.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "firebase": "^12.8.0",
    "helmet": "^8.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zod": "^3.25.76",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.25",
    "@angular/cli": "^19.2.25",
    "@angular/compiler-cli": "^19.2.22",
    "@angular/language-service": "^19.2.22",
    "@capacitor/android": "^7.4.4",
    "@capacitor/cli": "^8.0.1",
    "@capacitor/core": "^7.4.4",
    "@capacitor/local-notifications": "^7.0.3",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@firebase/rules-unit-testing": "^3.0.4",
    "@ngrx/store-devtools": "^19.2.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@sentry/cli": "^3.6.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^4.17.17",
    "@types/jasmine": "^5.1.15",
    "@types/jest": "^29.5.14",
    "@types/node": "^18.19.130",
    "angular-eslint": "21.0.1",
    "axe-core": "^4.11.1",
    "cypress": "^15.8.2",
    "cypress-axe": "^1.7.0",
    "eslint": "^9.39.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "husky": "^9.1.7",
    "imagemin": "^9.0.1",
    "jasmine-core": "~5.1.0",
    "jest": "^29.7.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "lint-staged": "^16.2.7",
    "semantic-release": "^25.0.5",
    "source-map-explorer": "^2.5.3",
    "start-server-and-test": "^2.1.3",
    "ts-jest": "^29.4.11",
    "typescript": "~5.8.3",
    "typescript-eslint": "8.46.4"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ],
    "*.html": [
      "eslint --fix"
    ]
  },
  "overrides": {
    "tar": "7.5.11",
    "serialize-javascript": "7.0.5",
    "file-type": "21.3.3",
    "ws": ">=8.20.1",
    "webpack-dev-server": ">=5.2.4",
    "@grpc/grpc-js": "1.9.16",
    "protobufjs": "7.6.5"
  }
}
