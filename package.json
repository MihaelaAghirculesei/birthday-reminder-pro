{
  "name": "birthday-reminder-pro",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "env:init": "node scripts/env-init.js",
    "prestart": "npm run env:init",
    "start": "ng serve --port=4203",
    "prebuild": "npm run env:init",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "build:stats": "ng build --configuration production --stats-json",
    "analyze": "npm run build:stats && webpack-bundle-analyzer dist/birthday-reminder-pro/browser/stats.json",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:coverage": "ng test --no-watch --code-coverage",
    "test:coverage:watch": "ng test --code-coverage",
    "test:ci": "ng test --no-watch --code-coverage",
    "e2e": "cypress open",
    "e2e:headless": "cypress run --config excludeSpecPattern=cypress/e2e/visual-regression.cy.ts",
    "pree2e:ci": "npx fkill :4203 --force --silent || true",
    "e2e:ci": "start-server-and-test start http://localhost:4203 e2e:headless",
    "e2e:visual": "cypress run --spec cypress/e2e/visual-regression.cy.ts",
    "pree2e:visual:ci": "npx fkill :4203 --force --silent || true",
    "e2e:visual:ci": "start-server-and-test start http://localhost:4203 e2e:visual",
    "serve:ssr:birthday-reminder-pro": "node dist/birthday-reminder-pro/server/server.mjs",
    "lint": "ng lint",
    "typecheck:app": "npx tsc --noEmit --strict --skipLibCheck -p tsconfig.app.json",
    "typecheck:spec": "npx tsc --noEmit --strict --skipLibCheck -p tsconfig.spec.json",
    "typecheck": "npm run typecheck:app && npm run typecheck:spec",
    "ci:audit": "npm audit --omit=dev --audit-level=high",
    "ci:bundle": "node scripts/check-bundle.js",
    "ci:security": "npm run ci:audit",
    "ci:quality": "npm run lint && npm run typecheck",
    "ci:build": "npm run build && npm run ci:bundle",
    "validate:ci": "node scripts/validate-ci.js",
    "ci:local": "npm run validate:ci && npm run ci:security && npm run ci:quality && npm run test:ci && npm run e2e:ci && npm run ci:build",
    "clean": "npx rimraf node_modules dist .angular",
    "clean:all": "npm cache clean --force && npx rimraf node_modules dist .angular",
    "prepare": "husky",
    "lighthouse:ci": "npm run build && npx rimraf .lighthouseci && npx lhci autorun"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.21",
    "@angular/cdk": "^19.2.19",
    "@angular/common": "^19.2.21",
    "@angular/compiler": "^19.2.21",
    "@angular/core": "^19.2.21",
    "@angular/forms": "^19.2.21",
    "@angular/material": "^19.2.19",
    "@angular/platform-browser": "^19.2.21",
    "@angular/platform-browser-dynamic": "^19.2.21",
    "@angular/platform-server": "^19.2.21",
    "@angular/router": "^19.2.21",
    "@angular/service-worker": "^19.2.21",
    "@angular/ssr": "^19.2.25",
    "@ngrx/effects": "^19.2.1",
    "@ngrx/entity": "^19.2.1",
    "@ngrx/store": "^19.2.1",
    "@ngx-translate/core": "^16.0.4",
    "compression": "^1.8.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "firebase": "^12.8.0",
    "helmet": "^8.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zod": "^3.25.76",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.25",
    "@angular/cli": "^19.2.25",
    "@angular/compiler-cli": "^19.2.21",
    "@angular/language-service": "^19.2.21",
    "@capacitor/android": "^7.4.4",
    "@capacitor/cli": "^8.0.1",
    "@capacitor/core": "^7.4.4",
    "@capacitor/local-notifications": "^7.0.3",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@lhci/cli": "^0.15.1",
    "@ngrx/store-devtools": "^19.2.1",
    "@types/compression": "^1.8.1",
    "@types/express": "^4.17.17",
    "@types/jasmine": "^5.1.15",
    "@types/node": "^18.19.130",
    "angular-eslint": "21.0.1",
    "axe-core": "^4.11.1",
    "cypress": "^15.8.2",
    "cypress-axe": "^1.7.0",
    "eslint": "^9.39.1",
    "fkill-cli": "^9.0.0",
    "husky": "^9.1.7",
    "imagemin": "^9.0.1",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "lint-staged": "^16.2.7",
    "source-map-explorer": "^2.5.3",
    "start-server-and-test": "^2.1.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "8.46.4",
    "webpack-bundle-analyzer": "^5.1.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ],
    "*.html": [
      "eslint --fix"
    ]
  },
  "overrides": {
    "tar": "7.5.11",
    "serialize-javascript": "7.0.5",
    "file-type": "21.3.3"
  }
}
